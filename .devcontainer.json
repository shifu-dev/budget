{
  "name": "Tauri",
  "runArgs": [
    // Without this the Tauri CLI will fail because it can't find a valid IP, and adb won't find your devices
    "--network=host"
    // "--device=/dev/kvm"
  ],
  "build": {
    "dockerfile": "dockerfile",
    "target": "devenv"
  },
  "remoteEnv": {
    "DISPLAY": "host.docker.internal:0"
  },
  "remoteUser": "root"
}
